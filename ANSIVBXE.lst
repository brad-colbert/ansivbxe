  1164 2CE2			cursor_toggle					; inverts the color of the current character to show the cursor
  1165 2CE2 A0 01				ldy	#1
  1166 2CE4 B1 80				lda	(cursor_address),y
  1167 2CE6 49 77				eor	#$77			; invert the color, but not bit 7 (transparency bit) or bit 3 (foreground intensity)
  1168 2CE8 91 80				sta	(cursor_address),y
  1169 2CEA A5 8C				lda	cursor_flg
  1170 2CEC 49 80				eor	#$80			; flip the cursor flag
  1171 2CEE 85 8C				sta	cursor_flg
  1172 2CF0 60					rts

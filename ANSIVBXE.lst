   280 				; start of loading files.
   281 				; make sure IOCB 1 is closed
   282
   283 2800-2F8E> A2 10				ldx	#$10
   284 2802 A9 0C				lda	#$0C
   285 2804 8D 52 03				sta	ICCOM+$10
   286 2807 20 56 E4				jsr	CIOV

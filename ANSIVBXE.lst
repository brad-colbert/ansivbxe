   523 				; open the R: device
   524 2939 A2 10				ldx	#$10
   525 293B A9 03				lda	#$03
   526 293D 8D 52 03				sta	ICCOM+$10
   527 2940 A9 6A				lda	<r_path
   528 2942 8D 54 03				sta	ICBA+$10
   529 2945 A9 2D				lda	>r_path
   530 2947 8D 55 03				sta	ICBA+$11
   531 294A A9 0D				lda	#$0D
   532 294C 8D 5A 03				sta	ICAX1+$10
   533 294F A9 00				lda	#0
   534 2951 8D 5B 03				sta	ICAX2+$10
   535 2954 20 56 E4				jsr	CIOV
   536 						
   537 				; configure it
   538 				; for now, 9600 baud, 8 data bits, no status line checking,
   539
   540 2957 A2 10				ldx	#$10
   541 2959 A9 24				lda	#36
   542 295B 8D 52 03				sta	ICCOM+$10
   543 295E A9 6A				lda	<r_path
   544 2960 8D 54 03				sta	ICBA+$10
   545 2963 A9 2D				lda	>r_path
   546 2965 8D 55 03				sta	ICBA+$11
   547 2968 A9 0E				lda	#14
   548 296A 8D 5A 03				sta	ICAX1+$10
   549 296D A9 00				lda	#0
   550 296F 8D 5B 03				sta	ICAX2+$10
   551 2972 20 56 E4				jsr	CIOV
   552 						
   553 				; no translation, ignore and do not change parity bit (input or output), and do not append LF to CR
   554 				 
   555 2975 A2 10				ldx	#$10
   556 2977 A9 26				lda	#38
   557 2979 8D 52 03				sta	ICCOM+$10
   558 297C A9 6A				lda	<r_path
   559 297E 8D 54 03				sta	ICBA+$10
   560 2981 A9 2D				lda	>r_path
   561 2983 8D 55 03				sta	ICBA+$11
   562 2986 A9 20				lda	#32
   563 2988 8D 5A 03				sta	ICAX1+$10
   564 298B A9 00				lda	#0
   565 298D 8D 5B 03				sta	ICAX2+$10
   566 2990 20 56 E4				jsr	CIOV
   567 						
   568 				; turn on DTR and RTS, and don't change xmt state
   569
   570 2993 A2 10				ldx	#$10
   571 2995 A9 22				lda	#34
   572 2997 8D 52 03				sta	ICCOM+$10
   573 299A A9 6A				lda	<r_path
   574 299C 8D 54 03				sta	ICBA+$10
   575 299F A9 2D				lda	>r_path
   576 29A1 8D 55 03				sta	ICBA+$11
   577 29A4 A9 F0				lda	#192+48
   578 29A6 8D 5A 03				sta	ICAX1+$10
   579 29A9 A9 00				lda	#0
   580 29AB 8D 5B 03				sta	ICAX2+$10
   581 29AE 20 56 E4				jsr	CIOV
   582 						
   583 				; start concurrent I/O
   584
   585 29B1 A2 10				ldx	#$10
   586 29B3 A9 28				lda	#40
   587 29B5 8D 52 03				sta	ICCOM+$10
   588 29B8 A9 6A				lda	<r_path
   589 29BA 8D 54 03				sta	ICBA+$10
   590 29BD A9 2D				lda	>r_path
   591 29BF 8D 55 03				sta	ICBA+$11
   592 29C2 A9 00				lda	#0
   593 29C4 8D 5A 03				sta	ICAX1+$10
   594 29C7 8D 5B 03				sta	ICAX2+$10
   595 29CA 20 56 E4				jsr	CIOV
   596 						
   597 						; set up the KB interupt handler now that R: is open.
   598 29CD 78					sei				; disable interupts before we set the new vector
   599 29CE A9 F1				lda	#<kbd_irq
   600 29D0 8D 08 02				sta	VKEYBD
   601 29D3 A9 2C				lda	#>kbd_irq
   602 29D5 8D 09 02				sta	VKEYBD+1
   603 29D8 58					cli				; re-enable interupts
   604 						
   605 29D9 20 2D 2D		wait_for_byte	jsr	check_sendbuf		; check to see if the send buffer has characters to be sent
   606
   607 29DC A2 10				ldx	#$10
   608 29DE A9 0D				lda	#13
   609 29E0 8D 52 03				sta	ICCOM+$10
   610 29E3 A9 6A				lda	<r_path
   611 29E5 8D 54 03				sta	ICBA+$10
   612 29E8 A9 2D				lda	>r_path
   613 29EA 8D 55 03				sta	ICBA+$11
   614 29ED A9 00				lda	#0
   615 29EF 8D 5A 03				sta	ICAX1+$10
   616 29F2 8D 5B 03				sta	ICAX2+$10
   617 29F5 20 56 E4				jsr	CIOV
   618 						
   619 29F8 AD EB 02				lda	DVSTAT1			; DVSTAT1 and 2 hold the number of bytes in the input buffer
   620 29FB 0D EC 02				ora	DVSTAT2
   621 29FE F0 D9				beq	wait_for_byte		; if they're 0, keep waiting
   622 						
   623 2A00				.local				; read bytes - right now this will get a max of 255 bytes, even though the buffer is
   624 2A00 A2 10				ldx	#$10			; 256 bytes. This could be fixed later. recvbuflen = 0 could mean 256, since the only
   625 2A02 A9 07				lda	#$07			; time execution reaches here is if there are more than 0 bytes to be processed.
   626 2A04 8D 52 03				sta	ICCOM+$10
   627 2A07 A9 8F				lda	#<recv_buffer
   628 2A09 8D 54 03				sta	ICBA + $10
   629 2A0C A9 2F				lda	#>recv_buffer
   630 2A0E 8D 55 03				sta	ICBA + $11
   631 2A11 AD EC 02				lda	DVSTAT2
   632 2A14 D0 06				bne	maxbuflen
   633 2A16 AD EB 02				lda	DVSTAT1
   634 2A19 4C 1E 2A				jmp	storebuflen
   635 2A1C A9 FF		maxbuflen	lda	#$FF
   636 2A1E 8D 58 03		storebuflen	sta	ICBL + $10
   637 2A21 85 8F				sta	recvbuflen
   638 2A23 A9 00				lda	#$0
   639 2A25 8D 59 03				sta	ICBL + $11
   640 2A28 A9 0D				lda	#$0D
   641 2A2A 8D 5A 03				sta	ICAX1 + $10		; turns out you need this for GET or it doesn't work.
   642 2A2D 20 56 E4				jsr	CIOV			; so after this, the receive buffer should have characters in it to be processed
   643 						
   644 2A30 A0 00				ldy	#0
   645 2A32 B9 8F 2F		next_byte	lda	recv_buffer, y		; get character from buffer
   646 2A35 85 8D				sta	temp_char		; put it here to pass to process_char
   647 2A37 98					tya
   648 2A38 48					pha				; push Y just in case
   649
   650 2A39 20 46 2A				jsr 	process_char		; process the character
   651
   652 2A3C 68					pla
   653 2A3D A8					tay				; get Y back
   654
   655 2A3E C8					iny				; next character
   656
   657 2A3F C4 8F				cpy	recvbuflen
   658 2A41 D0 EF				bne	next_byte		; if they're not equal, we get the next byte
   659 						
   660 2A43 4C D9 29				jmp	wait_for_byte
   661 						.endl
   662
   663 2A46			process_char	.local
   664 2A46 24 8B				bit	ctrl_seq_flg
   665 2A48 70 0F				bvs	is_ctrl_seq		; if overflow set, it's a control sequence
   666 2A4A 10 32				bpl	not_C1			; if escape flag not set, it's not a C1 character
   667 2A4C A9 00				lda	#0			; if it is, we clear the escape flag for the next character.
   668 2A4E 85 8B				sta	ctrl_seq_flg
   669 2A50 A5 8D				lda	temp_char
   670 2A52 29 E0				and	#%11100000		; AND mask for C1 set
   671 2A54 C9 40				cmp	#$40			; if it's $40 after ANDing,
   672 2A56 F0 40				beq	is_C1			; it's part of the C1 set
   673 2A58 60					rts				; otherwise, it's some other character preceded by escape, which we do nothing with (don't even print it)
   674
   675 2A59			is_ctrl_seq	.local
   676 2A59 A5 8D				lda	temp_char
   677 2A5B C9 20				cmp	#$20
   678 2A5D 90 11				bcc	bad_ctrl_seq		; control sequence is bad if character isn't greater than or equal to #$20
   679 2A5F C9 7F				cmp	#$7F			; control sequence is bad if character is greater than or equal to #$7F
   680 2A61 B0 0D				bcs	bad_ctrl_seq		; this is all in the ECMA 48 spec.
   681 2A63 A6 92				ldx	ctrl_seq_index		; get index
   682 2A65 9D 8F 31				sta	ctrl_seq_buf,x		; store byte in the buffer
   683 2A68 E8					inx
   684 2A69 86 92				stx	ctrl_seq_index
   685 2A6B C9 40				cmp	#$40			; if control sequence byte is greater than or equal to #$40, then it's the final byte.
   686 2A6D B0 06				bcs	is_final_byte
   687 2A6F 60					rts
   688 						
   689 2A70 A9 00		bad_ctrl_seq	lda	#0
   690 2A72 85 8B				sta	ctrl_seq_flg
   691 2A74 60					rts
   692 						
   693 2A75 85 93		is_final_byte	sta	final_byte
   694 2A77 A9 00				lda	#0
   695 2A79 85 8B				sta	ctrl_seq_flg
   696 2A7B 4C AB 2A				jmp	do_ctrl_seq
   697 						.endl
   698 						
   699
   700 2A7E A5 8D		not_C1		lda	temp_char
   701 2A80 C9 20				cmp	#32
   702 2A82 90 03				bcc	is_C0			; if the character is less than 32, it's a part of the C0 control set
   703 						
   704 2A84 4C EA 2A				jmp	put_byte		; if it's not part of the C0 set, just print it.
   705
   706 						
   707 2A87 0A			is_C0		asl				; multiply by two to get an offset into the C0 handler table
   708 2A88 AA					tax				; transfer to X to be used as an index
   709 2A89 BD FA 2D				lda	C0_handler_table, x	; transfer the address of the proper handler
   710 2A8C 8D 96 2A				sta	jump_C0 + 1
   711 2A8F BD FB 2D				lda	C0_handler_table + 1, x
   712 2A92 8D 97 2A				sta	jump_C0 + 2
   713 2A95 4C 00 00		jump_C0		jmp	$0000			; into the operand of this JSR
   714 								
   715 2A98			is_C1
   716 2A98 A5 8D				lda	temp_char
   717 2A9A 0A					asl
   718 2A9B AA					tax
   719 2A9C BD BA 2D				lda	C1_handler_table-$80,x	; transfer the address of the proper handler
   720 2A9F 8D A9 2A				sta	jump_C1 + 1
   721 2AA2 BD BB 2D				lda	C1_handler_table-$7F,x
   722 2AA5 8D AA 2A				sta	jump_C1 + 2
   723 2AA8 4C 00 00		jump_C1		jmp	$0000
   724 						.endl
   725 						
   726 2AAB			do_ctrl_seq	.local
   727 2AAB A6 92				ldx	ctrl_seq_index
   728 2AAD CA					dex
   729 2AAE CA					dex
   730 2AAF BD 8F 31				lda	ctrl_seq_buf,x
   731 2AB2 C9 30				cmp	#$30
   732 2AB4 B0 05				bcs	no_inter_byte		; if this byte is less than #$30, it's an intermediate byte.
   733 2AB6 85 94				sta	inter_byte
   734 2AB8 4C BF 2A				jmp	find_entry
   735 2ABB A9 00		no_inter_byte	lda	#0
   736 2ABD 85 94				sta	inter_byte
   737 						
   738 2ABF A2 00		find_entry	ldx	#0
   739 2AC1 BD 7A 2E		next_entry	lda	ctrl_seq_table,x	; get final byte from table
   740 2AC4 F0 23				beq	last_entry		; if the last entry is reached, jump
   741 2AC6 C5 93				cmp	final_byte		; compare to actual final byte
   742 2AC8 D0 18				bne	wrong_f_byte		; jump if they don't match
   743 2ACA E8					inx
   744 2ACB BD 7A 2E				lda	ctrl_seq_table,x	; get intermediate byte
   745 2ACE C5 94				cmp	inter_byte		; compare to actual intermediate byte
   746 2AD0 D0 11				bne	wrong_i_byte		; jump if they don't match
   747 2AD2 E8					inx				; point at low address of handler
   748 2AD3 BD 7A 2E				lda	ctrl_seq_table,x
   749 2AD6 8D E0 2A				sta	ctrl_seq_jmp+1
   750 2AD9 BD 7B 2E				lda	ctrl_seq_table+1,x
   751 2ADC 8D E1 2A				sta	ctrl_seq_jmp+2		; set up the jump
   752 						
   753 2ADF 4C 00 00		ctrl_seq_jmp	jmp	$0000			; jump to control sequence handler (the address here will be changed)
   754 						
   755 2AE2 E8			wrong_f_byte	inx				; points to intermediate byte after this
   756 2AE3 E8			wrong_i_byte	inx				; points to low address byte after this
   757 2AE4 E8					inx				; points to high address byte after this
   758 2AE5 E8					inx				; points to next final byte after this
   759 2AE6 4C C1 2A				jmp	next_entry
   760 						
   761 2AE9 60			last_entry	rts				; if we searched the whole list and didn't find it, do nothing.
   762 						.endl
   763
   764
   765 2AEA			put_byte	.local				; put the byte on the screen
   766 2AEA 20 DD 2C				jsr	cursor_off
   767 2AED A2 00				ldx	#$00
   768 2AEF A5 8D				lda	temp_char
   769 2AF1 81 80				sta	(cursor_address, x)
   770 2AF3 E6 80				inc	cursor_address
   771 2AF5 A5 82				lda	text_color		; get the current text color
   772 2AF7 81 80				sta	(cursor_address, x)
   773 2AF9 E6 80				inc	cursor_address
   774 2AFB D0 02				bne	no_carry		; if the increment resulted in 0, then we rolled over and need to carry
   775 2AFD E6 81				inc	cursor_address + 1	; carry means high address needs to be incremented
   776 2AFF E6 84		no_carry	inc	column			; move the cursor forward
   777 2B01 A9 4F				lda	#79
   778 2B03 C5 84				cmp	column
   779 2B05 B0 0C				bcs	no_new_line		; if 79 >= col, no new line is needed
   780 2B07 A5 83				lda	row
   781 2B09 C9 17				cmp	#23			; if row is 23, then we need to scroll a line
   782 2B0B F0 09				beq	scroll
   783 2B0D E6 83				inc	row			; otherwise (when col > 79) go to the next line
   784 2B0F A9 00				lda	#00
   785 2B11 85 84				sta	column			; set column back to 0
   786 2B13 4C D8 2C		no_new_line	jmp	cursor_on
   787
   788 2B16 A9 60		scroll		lda	#<(vbxe_mem_base + $1000 - 160)
   789 2B18 85 80				sta	cursor_address
   790 2B1A A9 AF				lda	#>(vbxe_mem_base + $1000 - 160)
   791 2B1C 85 81				sta	cursor_address + 1
   792 						/*
   793 						lda	cursor_address		; what do I do this for? this is really unnecesary, all this math
   794 						sec				; I know that the only time I jump here is when I am pointing off the bottom of the
   795 						sbc	#160			; screen, just past the end of the VBXE window. so this math always results in the same
   796 						sta	cursor_address		; thing.
   797 						bcs	no_carry_1		; if carry clear (borrow)
   798 						dec	cursor_address+1	; decrement the high byte
   799 						*/
   799
   800 2B1E A9 00		no_carry_1	lda	#0			; otherwise, don't
   801 2B20 85 84				sta	column			; set column to 0. row stays 23
   802 2B22 20 80 2C				jsr	scroll_1d		; run the blitter routine to scroll one line down.
   803 2B25 4C D8 2C				jmp	cursor_on
   804 						.endl
   805
   806 				;###################################################################################################################
   807 				; control sequence handlers
   808 2B28			SOH_adr						; Start of Header prints a character
   809 2B28			STX_adr						; Start of Text prints a character
   810 2B28			ETX_adr						; End of Text prints a character
   811 2B28			EOT_adr						; End of Transmission prints a character
   812 2B28			ACK_adr						; Acknowledge prints a character
   813 2B28			SO_adr						; Shift Out prints a character
   814 2B28			SI_adr						; Shift In prints a character
   815 2B28			DLE_adr						; Data Link Escape prints a character
   816 2B28			DC1_adr						; Device Control 1-4 print a character
   817 2B28			DC2_adr
   818 2B28			DC3_adr
   819 2B28			DC4_adr
   820 2B28			NAK_adr						; Non-Acknowledge prints a character
   821 2B28			SYN_adr						; Synchronous Idle prints a character
   822 2B28			ETB_adr						; End of Transmission Block prints a character
   823 2B28			CAN_adr						; Cancel prints a character
   824 2B28			EM_adr						; End of Medium prints a character
   825 2B28			SUB_adr						; Substitute prints a character
   826 2B28			IS1_adr						; Information Separator 1-4 print characters
   827 2B28			IS2_adr
   828 2B28			IS3_adr
   829 2B28			IS4_adr
   830 2B28 4C EA 2A				jmp 	put_byte		; the put_byte routine will return for us
   831 2B2B			ESC_adr						; Escape sets the escape flag
   832 2B2B A9 80				lda	#$80
   833 2B2D 85 8B				sta	ctrl_seq_flg
   834 2B2F 60					rts
   835 2B30			CSI_adr						; Control Sequence Introducer sets the CSI flag which causes interpretation of a control sequence to begin
   836 2B30 A9 00				lda	#0
   837 2B32 85 92				sta	ctrl_seq_index
   838 2B34 A9 40				lda	#$40
   839 2B36 85 8B				sta	ctrl_seq_flg
   840 2B38 60					rts
   841 2B39			VT_adr						; Vertical Tab. for now, same as LF
   842 2B39			IND_adr						; Index is same as LF
   843 2B39			LF_adr		.local				; Line Feed moves the cursor down one line BUT only if we're not on the last line
   844 										; down one line is forward 80 columns, or 160 bytes
   845 2B39 20 DD 2C				jsr	cursor_off
   846 2B3C A5 83				lda	row
   847 2B3E C9 17				cmp	#23			; if row is at 24,
   848 2B40 F0 10				beq	scroll			; we scroll
   849 2B42 A9 A0				lda	#160			; otherwise, we add 160.
   850 2B44 18					clc				; clear the carry in prep for the addition.
   851 2B45 65 80				adc	cursor_address		; add 160 to the low part of the cursor address.
   852 2B47 85 80				sta	cursor_address
   853 2B49 90 02				bcc	no_carry		; if there's a carry,
   854 2B4B E6 81				inc	cursor_address + 1	; increment the high half of the address.
   855 2B4D E6 83		no_carry	inc	row			; Line Feed increments row
   856 2B4F 4C D8 2C				jmp	cursor_on
   857 2B52 20 80 2C		scroll		jsr	scroll_1d		; scroll one line down. we don't need to touch the cursor address, the row, or column.
   858 2B55 4C D8 2C				jmp	cursor_on
   859 						.endl
   860
   861 2B58			CR_adr		.local				; Carriage Return puts the cursor at the home position of the current line 
   862 				                                                ; (AKA, cursor gets column number * 2 bytes/char subtracted from it)
   863 2B58 20 DD 2C				jsr	cursor_off
   864 2B5B A5 80				lda	cursor_address		; get cursor
   865 2B5D 38					sec				; set carry for subtraction
   866 2B5E E5 84				sbc	column			; do the subtraction
   867 2B60 B0 02				bcs	no_borrow1		; carry will be clear if no borrow
   868 2B62 C6 81				dec	cursor_address + 1	; otherwise it borrowed, so decrement cursor_address high byte
   869 2B64 38			no_borrow1	sec				; prepare for another subtraction
   870 2B65 E5 84				sbc	column			; do it
   871 2B67 B0 02				bcs	no_borrow2		; borrow thing again...
   872 2B69 C6 81				dec	cursor_address + 1
   873 2B6B 85 80		no_borrow2	sta	cursor_address		; store the result
   874 2B6D A9 00				lda 	#00
   875 2B6F 85 84				sta	column			; set column to 0
   876 2B71 4C D8 2C				jmp	cursor_on
   877 						.endl
   878
   879 2B74			BEL_adr		.local				; Bell is supposed to play a tone, flash the screen, something.
   880 										; this routine is copied out of the atari OS. it is what Atari used to do a bell character.
   881 										; it's slightly modified. the original routine called the keyclick routine 32 (#$20) times.
   882 										; I use a nested loop.
   883 										; perhaps later, I will separate the keyclick routine for my own purposes.
   884 2B74 A0 20				ldy	#$20
   885 2B76 A2 7E		repeat		ldx	#$7E
   886 2B78 8E 1F D0		spk		stx	CONSOL
   887 2B7B AD 0B D4				lda	VCOUNT
   888 2B7E CD 0B D4		wait		cmp	VCOUNT
   889 2B81 F0 FB				beq	wait
   890 2B83 CA					dex
   891 2B84 CA					dex
   892 2B85 10 F1				bpl	spk
   893 2B87 88					dey
   894 2B88 10 EC				bpl	repeat
   895 2B8A 60					rts
   896 						.endl
   897 						
   898 2B8B			FF_adr						; Form Feed clears the screen and sets cursor to the home position.
   899 2B8B 20 DD 2C				jsr	cursor_off
   900 2B8E A9 00				lda	#0			; home the cursor
   901 2B90 85 83				sta	row
   902 2B92 85 84				sta	column
   903 2B94 A9 00				lda	#<vbxe_screen_top
   904 2B96 85 80				sta	cursor_address
   905 2B98 A9 A1				lda	#>vbxe_screen_top
   906 2B9A 85 81				sta	cursor_address + 1
   907 2B9C 20 AC 2C				jsr	scroll_page		; clear the screen
   908 2B9F 4C D8 2C				jmp	cursor_on
   909 						
   910 2BA2			BS_adr		.local				; Back Space moves the cursor left by one character (2 bytes).
   911 2BA2 20 DD 2C				jsr	cursor_off
   912 2BA5 A5 84				lda	column
   913 2BA7 D0 01				bne	not_left		; if we're not at the left side yet, keep going
   914 2BA9 60					rts				; but if we ARE at the left side, do nothing
   915 2BAA C6 84		not_left	dec	column			; if column isn't 0, we just decrement it
   916 2BAC A5 80				lda	cursor_address
   917 2BAE D0 02				bne	no_borrow		; if the cursor address low half isn't 0, we don't borrow
   918 2BB0 C6 81				dec	cursor_address + 1	; otherwise, borrow
   919 2BB2 C6 80		no_borrow	dec	cursor_address		; if it weren't for the fact that cursor_address should always be even,
   920 2BB4 C6 80				dec 	cursor_address		; we would have to look for a borrow here too.
   921 2BB6 4C D8 2C				jmp	cursor_on
   922 						.endl
   923 2BB9			NUL_adr						; null does nothing
   924 2BB9			ENQ_adr						; Enquiry is probably supposed to return an ACK, but for now, it does nothing
   925 2BB9			HT_adr						; Horizontal Tab normally causes the cursor to move to the next tab stop. for now, nothing
   926 2BB9			HTS_adr						; no tab stuff just yet
   927 2BB9			HTJ_adr
   928 2BB9			VTS_adr
   929 2BB9			BPH_adr						; BPH doesn't apply in this case.
   930 2BB9			NBH_adr						; nor do any of the following
   931 2BB9			SSA_adr
   932 2BB9			ESA_adr
   933 2BB9			PLD_adr
   934 2BB9			PLU_adr
   935 2BB9			RI_adr
   936 2BB9			SS2_adr
   937 2BB9			SS3_adr
   938 2BB9			DCS_adr
   939 2BB9			PU1_adr
   940 2BB9			PU2_adr
   941 2BB9			STS_adr
   942 2BB9			CCH_adr
   943 2BB9			MW_adr
   944 2BB9			SPA_adr
   945 2BB9			EPA_adr
   946 2BB9			SOS_adr
   947 2BB9			SCI_adr
   948 2BB9			ST_adr
   949 2BB9			OSC_adr
   950 2BB9			PM_adr
   951 2BB9			APC_adr
   952 2BB9 60					rts
   953 2BBA			NEL_adr						; Next Line is combination of CR and LF
   954 2BBA 20 58 2B				jsr	CR_adr
   955 2BBD 4C 39 2B				jmp	LF_adr

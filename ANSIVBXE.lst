    12 				;	OS Equates
    13 				;###################################################################################################################
    14 				; IOCB equates
    15 = 0342			ICCOM		equ	$342			; command
    16 = 0343			ICSTA		equ	$343			; status
    17 = 0344			ICBA		equ	$344			; 2 bytes, buffer address for data or filename
    18 = 0348			ICBL		equ	$348			; 2 bytes, buffer length
    19 = 034A			ICAX1		equ	$34A			; Auxiliary byte 1
    20 = 034B			ICAX2		equ	$34B			; Auxiliary byte 2
    21
    22 = 02EA			DVSTAT0		equ	$2EA			; holds that status bytes after a status command
    23 = 02EB			DVSTAT1		equ	$2EB
    24 = 02EC			DVSTAT2		equ	$2EC
    25 = 02ED			DVSTAT3		equ	$2ED
    26 				; OS vectors and addresses
    27 = E456			CIOV		equ	$E456			; address for CIO
    28 = 000A			DOSVEC		equ	$A			; vector for DOS
    29 = 0208			VKEYBD		equ	$208			; vector for KB interupt
    30 				; OS variables and shadow registers
    31 = 022F			SDMCTL		equ	$22F			; DMA Control
    32 = 0012			RTCLOK		equ	$12			; jiffy counter
    33 = 02F2			CH1		equ	$2F2			; used for KB IRQ
    34 = 02F1			KEYDEL		equ	$2F1			; key delay counter for debouncing
    35 = 004D			ATRACT		equ	$4D			; attract mode timer/flag
    36 = 022B			SRTIMR		equ	$22B			; key repeat delay counter. decremented once every jiffy.
    35 						icl	'atarihardware.equ'	; general atari hardware equates,

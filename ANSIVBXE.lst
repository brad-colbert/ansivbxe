   957 2BC0			SGR_adr		.local				; set graphics rendition control sequence
   958 2BC0 A2 FF				ldx	#$FF
   959 2BC2 A9 00		next_parm	lda	#0
   960 2BC4 85 95				sta	parameter_val		; zero parameter value, this is the default value for this control sequence also
   961 2BC6 E8			next_byte	inx				; increment index
   962 2BC7 BD 8F 31				lda	ctrl_seq_buf,x		; get byte of control sequence
   963 2BCA A8					tay				; save original value
   964 2BCB 29 F0				and	#$F0
   965 2BCD C9 30				cmp	#$30			; if it's #$3x, then it's a parameter value
   966 2BCF D0 27				bne	is_last_parm		; otherwise, it has to be the final byte.
   967 2BD1 98					tya				; get value back
   968 2BD2 C9 3A				cmp	#$3A
   969 2BD4 90 09				bcc	add_digit		; if it's less than #$3A, then append the digit to parameter_val
   970 2BD6 F0 EE				beq	next_byte		; if it's #$3A, then ignore it
   971 2BD8 C9 3B				cmp	#$3B
   972 2BDA F0 16				beq	parse_parm		; if it's #$3B, then it's the end of a parameter substring
   973 2BDC 4C C6 2B				jmp	next_byte		; otherwise, at this point, it must be a bad value (#$3C through #$3F)
   974
   975 2BDF 29 0F		add_digit	and	#$0F			; we just want the last 4 bits
   976 2BE1 A8					tay				; save this
   977 2BE2 A5 95				lda	parameter_val		; append the digit to parameter_val
   978 2BE4 0A					asl
   979 2BE5 0A					asl
   980 2BE6 0A					asl
   981 2BE7 0A					asl
   982 2BE8 85 95				sta	parameter_val
   983 2BEA 98					tya
   984 2BEB 05 95				ora	parameter_val
   985 2BED 85 95				sta	parameter_val
   986 2BEF 4C C6 2B				jmp	next_byte
   987 						
   988 2BF2			parse_parm
   989 2BF2 20 F8 2B				jsr	is_last_parm
   990 2BF5 4C C2 2B				jmp	next_parm
   991 						
   992 2BF8			is_last_parm	.local
   993 2BF8 A5 95				lda	parameter_val
   994 2BFA 29 F0				and	#$F0
   995 2BFC F0 09				beq	simple_attrib		; if it's zero, it's a simple attribute (bold, inverse, etc.)
   996 2BFE C9 30				cmp	#$30
   997 2C00 F0 32				beq	forecolor_attr		; foreground (text) color change
   998 2C02 C9 40				cmp	#$40
   999 2C04 F0 41				beq	backcolor_attr		; background color change
  1000 2C06 60					rts				; otherwise it's not supported
  1001
  1002 2C07			simple_attrib	.local
  1003 2C07 A5 95				lda	parameter_val
  1004 2C09 29 0F				and	#$0F
  1005 2C0B F0 0D				beq	default
  1006 2C0D C9 01				cmp	#$1
  1007 2C0F F0 0E				beq	bold
  1008 2C11 C9 02				cmp	#$2
  1009 2C13 F0 11				beq	unbold
  1010 2C15 C9 07				cmp	#$7
  1011 2C17 F0 14				beq	inverse
  1012 2C19 60					rts
  1013
  1014 2C1A A9 87		default		lda	#$87
  1015 2C1C 85 82				sta	text_color
  1016 2C1E 60					rts
  1017 						
  1018 2C1F A5 82		bold		lda	text_color
  1019 2C21 09 08				ora	#%00001000
  1020 2C23 85 82				sta	text_color
  1021 2C25 60					rts
  1022 						
  1023 2C26 A5 82		unbold		lda	text_color
  1024 2C28 29 F7				and	#%11110111
  1025 2C2A 85 82				sta	text_color
  1026 2C2C 60					rts
  1027 						
  1028 2C2D A5 82		inverse		lda	text_color
  1029 2C2F 49 77				eor	#%01110111
  1030 2C31 85 82				sta	text_color
  1031 2C33 60					rts
  1032 						.endl
  1033 						
  1034 2C34			forecolor_attr	.local
  1035 2C34 A5 95				lda	parameter_val
  1036 2C36 C9 38				cmp	#$38
  1037 2C38 B0 0C				bcs	ignore
  1038 2C3A 29 0F				and	#$0F
  1039 2C3C 85 95				sta	parameter_val
  1040 2C3E A5 82				lda	text_color
  1041 2C40 29 F8				and	#$F8
  1042 2C42 05 95				ora	parameter_val
  1043 2C44 85 82				sta	text_color
  1044 2C46 60			ignore		rts
  1045 						.endl
  1046 						
  1047 2C47			backcolor_attr	.local
  1048 2C47 A5 95				lda	parameter_val
  1049 2C49 C9 48				cmp	#$48
  1050 2C4B B0 10				bcs	ignore
  1051 2C4D 29 0F				and	#$0F
  1052 2C4F 0A					asl
  1053 2C50 0A					asl
  1054 2C51 0A					asl
  1055 2C52 0A					asl
  1056 2C53 85 95				sta	parameter_val
  1057 2C55 A5 82				lda	text_color
  1058 2C57 29 8F				and	#$8F
  1059 2C59 05 95				ora	parameter_val
  1060 2C5B 85 82				sta	text_color
  1061 2C5D 60			ignore		rts
  1062 						.endl
  1063 						
  1064 						.endl
  1065
  1066 						.endl
  1067 						
  1068 2C5E			mem_move	.local				; memory move routine.
  1069 				; copies number of bytes in counter + 1 from address in src_ptr to address in dst_ptr
  1070
  1071 2C5E A0 00				ldy	#0			; we don't want an offset actually, but the 6502 uses one anyway
  1072 2C60 B1 85		loop		lda	(src_ptr),y		; move a byte
  1073 2C62 91 87				sta	(dst_ptr),y
  1074 2C64 E6 85				inc	src_ptr			; increment the pointer
  1075 2C66 D0 02				bne	no_carry_0		; if it rolled over (to zero)
  1076 2C68 E6 86				inc	src_ptr+1		; then increment the high byte
  1077 2C6A E6 87		no_carry_0	inc	dst_ptr			; increment the other pointer
  1078 2C6C D0 02				bne	no_carry_1
  1079 2C6E E6 88				inc	dst_ptr+1
  1080 2C70 A5 89		no_carry_1	lda	counter			; check to see if count is 0
  1081 2C72 D0 06				bne	no_borrow		; if it's not, we don't borrow
  1082 2C74 A5 8A				lda	counter+1		; check to see if count's high byte is 0 also
  1083 2C76 F0 07				beq	done			; in which case we're done
  1084 2C78 C6 8A				dec	counter+1		; but if we're not, we borrow
  1085 2C7A C6 89		no_borrow	dec	counter
  1086 2C7C 4C 60 2C				jmp	loop
  1087 2C7F 60			done		rts
  1088 						.endl
  1089
  1090 2C80			scroll_1d	.local				; scroll one down routine.
  1091 				; uses the blitter to move everything up just one line.
  1092
  1093 2C80 AD 5F D6				lda	memac_bank_sel		; get the old bank number (should be the last bank, but we can't assume)
  1094 2C83 48					pha
  1095 						
  1096 2C84 A9 80				lda	#$80			; bank 0, so we can put the color byte as the fill byte
  1097 2C86 8D 5F D6				sta	memac_bank_sel
  1098 						
  1099 2C89 A5 82				lda	text_color		; put the color in the fill pattern location.
  1100 2C8B 8D 48 A8				sta	scroll_1d_color-xdl+$0800+vbxe_mem_base
  1101 						
  1102 2C8E A9 0E				lda	#<(bcb_one_down - xdl + $800)
  1103 2C90 8D 50 D6				sta	blt_adr
  1104 2C93 A9 08				lda	#>(bcb_one_down - xdl + $800)
  1105 2C95 8D 51 D6				sta	blt_adr+1
  1106 2C98 A9 00				lda	#^(bcb_one_down - xdl + $800)
  1107 2C9A 8D 52 D6				sta	blt_adr+2

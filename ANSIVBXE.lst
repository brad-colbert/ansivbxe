   331 				; open the pallette file
   332
   333 2855 A2 10				ldx	#$10
   334 2857 A9 03				lda	#$03
   335 2859 8D 52 03				sta	ICCOM+$10
   336 285C A9 5F				lda	<pallette_path
   337 285E 8D 54 03				sta	ICBA+$10
   338 2861 A9 2D				lda	>pallette_path
   339 2863 8D 55 03				sta	ICBA+$11
   340 2866 A9 04				lda	#$04
   341 2868 8D 5A 03				sta	ICAX1+$10
   342 286B A9 00				lda	#$00
   343 286D 8D 5B 03				sta	ICAX2+$10
   344 2870 20 56 E4				jsr	CIOV
   345
   346 				; read the pallette to a temporary location inside VBXE memory (which we know is free for now)
   347
   348 2873 A2 10				ldx	#$10			; IOCB 1
   349 2875 A9 07				lda	#$07			; read binary record
   350 2877 8D 52 03				sta	ICCOM+$10
   351 287A A9 00				lda	#$00			; buffer address is vbxe_mem_base + $0800
   352 287C 8D 54 03				sta	ICBA+$10
   353 287F A9 A8				lda	#>vbxe_mem_base + $08
   354 2881 8D 55 03				sta	ICBA+$11
   355 2884 A9 30				lda	#$30			; buffer length is 48 bytes ($30)
   356 2886 8D 58 03				sta	ICBL+$10
   357 2889 A9 00				lda	#$00
   358 288B 8D 59 03				sta	ICBL+$11
   359 288E 20 56 E4				jsr	CIOV
   360
   361 				; close the pallette, we have it in RAM now
   362
   363 2891 A2 10				ldx	#$10
   364 2893 A9 0C				lda	#$0C
   365 2895 8D 52 03				sta	ICCOM+$10
   366 2898 20 56 E4				jsr	CIOV
   367
   368 				; initialize csel and psel to start loading colors into the pallette
   369
   370 289B A9 00				lda	#$00
   371 289D 8D 44 D6				sta	psel
   372 28A0 8D 45 D6				sta	csel
   373
   374 28A3			.local		; load the foreground colors into the VBXE
   375 				; we use a nested loop here due to the design of the text mode colors
   376 				; we need to load the 16 foreground colors into the first 128 colors in order, and do that 8 times
   377 				; this order will be like:
   378 				; col 1, col 2, col 3, ..., col F, col 1, col 2 etc.
   379
   380 28A3 A0 00				ldy	#$00			; initialize the outer loop counter
   381 28A5 A2 00		fore_outer_loop	ldx	#$00			; initialize the inner loop counter
   382 28A7 BD 00 A8		fore_inner_loop	lda	vbxe_mem_base + $0800,x	; load the color values. use index x because of the order we need to load colors in
   383 28AA 8D 46 D6				sta	cr
   384 28AD BD 01 A8				lda	vbxe_mem_base + $0801,x
   385 28B0 8D 47 D6				sta	cg
   386 28B3 BD 02 A8				lda	vbxe_mem_base + $0802,x
   387 28B6 8D 48 D6				sta	cb
   388 28B9 E8					inx				; increment 3 times because each color is 3 bytes
   389 28BA E8					inx
   390 28BB E8					inx
   391 28BC E0 30				cpx	#$30			; once x is equal to $30, we have loaded all the colors
   392 28BE D0 E7				bne	fore_inner_loop
   393 					
   394 28C0 C8					iny				; increment the outer loop counter
   395 28C1 C0 08				cpy	#$08			; so we can do it for 8 times total
   396 28C3 D0 E0				bne	fore_outer_loop
   397 				.endl
   398
   399
   400 28C5			.local		; load the background colors into the VBXE
   401 				; we use a nested loop here, but differently again due to the design of text mode colors
   402 				; we need to load the 8 background colors 16 times in a row each
   403 				; that is, load color 0 16 times, then load color 1 16 times, etc.
   404
   405 28C5 A0 00				ldy	#$00			; initialize the outer loop counter
   406 28C7 A2 00		back_outer_loop	ldx	#$00			; initialize the inner loop counter
   407 28C9 B9 00 A8		back_inner_loop	lda	vbxe_mem_base + $0800,y	; load the color values. use index y because we load each color repeatedly
   408 28CC 8D 46 D6				sta	cr
   409 28CF B9 01 A8				lda	vbxe_mem_base + $0801,y
   410 28D2 8D 47 D6				sta	cg
   411 28D5 B9 02 A8				lda	vbxe_mem_base + $0802,y
   412 28D8 8D 48 D6				sta	cb
   413 28DB E8					inx				; increment the inner loop
   414 28DC E0 10				cpx	#$10			; stop after the color has been loaded 16 times
   415 28DE D0 E9				bne	back_inner_loop
   416 28E0 C8					iny				; increment 3 times because each color is 3 bytes
   417 28E1 C8					iny
   418 28E2 C8					iny
   419 28E3 C0 18				cpy	#$18			; when we get to $18, we have loaded all the background colors
   420 28E5 D0 E0				bne	back_outer_loop
   421 				.endl
   422 				; load the xdl and blitter lists
   423
   424 28E7 A9 6E				lda	#<xdl			; setup source pointer
   425 28E9 85 85				sta	src_ptr
   426 28EB A9 2D				lda	#>xdl
   427 28ED 85 86				sta	src_ptr+1
   428 						
   429 28EF A9 00				lda	#<(vbxe_mem_base+$0800)	; destination pointer
   430 28F1 85 87				sta	dst_ptr
   431 28F3 A9 A8				lda	#>(vbxe_mem_base+$0800)
   432 28F5 85 88				sta	dst_ptr+1
   433 						
   434 28F7 A9 8B				lda	#<(bcb_end - xdl - 1)	; and byte count - 1
   435 28F9 85 89				sta	counter
   436 28FB A9 00				lda	#>(bcb_end - xdl)
   437 28FD 85 8A				sta	counter+1

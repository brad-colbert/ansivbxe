  1286 2D7F A0 00		                .word	80*2			; one line is 160 bytes wide, and we're working our way down, so positive
  1287 2D81 01			                .byte	1			; x step is 1 (we want forwards and to not skip stuff)
  1288 2D82 00 B5 07		                .long	$07B500			; top of VBXE ram is $80000. this address is 5 pages back. (dst)
  1289 2D85 A0 00		                .word	80*2			; x and y step is the same as the source ones
  1290 2D87 01			                .byte	1
  1291 2D88 9F 00		                .word	[80*2]-1		; width same as y step less one

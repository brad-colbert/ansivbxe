   288 				; open the font file in IOCB 1
   289
   290 280A A2 10				ldx	#$10
   291 280C A9 03				lda	#$03
   292 280E 8D 52 03				sta	ICCOM+$10
   293 2811 A9 53				lda	<font_path
   294 2813 8D 54 03				sta	ICBA+$10
   295 2816 A9 2D				lda	>font_path
   296 2818 8D 55 03				sta	ICBA+$11
   297 281B A9 04				lda	#$04
   298 281D 8D 5A 03				sta	ICAX1+$10
   299 2820 A9 00				lda	#$00
   300 2822 8D 5B 03				sta	ICAX2+$10
   301 2825 20 56 E4				jsr	CIOV
   302 					
   303 				; set bank to beginning of VBXE memory with bit 7 set to enable the window
   304 				; this is where we will load the font
   305
   306 2828 A9 80				lda	#$80
   307 282A 8D 5F D6				sta	memac_bank_sel
   308
   309 				; load the entire (2K) font into the VBXE memory window
   310
   311 282D A2 10				ldx	#$10			; IOCB 1
   312 282F A9 07				lda	#$07			; read binary record
   313 2831 8D 52 03				sta	ICCOM+$10
   314 2834 A9 00				lda	#$00			; buffer address is vbxe_mem_base
   315 2836 8D 54 03				sta	ICBA+$10
   316 2839 A9 A0				lda	#>vbxe_mem_base
   317 283B 8D 55 03				sta	ICBA+$11
   318 283E A9 00				lda	#$00			; buffer length is 2K
   319 2840 8D 58 03				sta	ICBL+$10
   320 2843 A9 08				lda	#$08
   321 2845 8D 59 03				sta	ICBL+$11
   322 2848 20 56 E4				jsr	CIOV
   323
   324 				; close the font file (we only need to load it once)
   325
   326 284B A2 10				ldx	#$10
   327 284D A9 0C				lda	#$0C
   328 284F 8D 52 03				sta	ICCOM+$10
   329 2852 20 56 E4				jsr	CIOV

  1293 2D8B FF					.byte	$FF			; AND mask. don't modify the data
  1294 2D8C 00					.byte	$00			; XOR mask. don't modify the data
  1295 2D8D 00					.byte	$00			; no collisions
  1296 2D8E 00					.byte	$00			; 1:1 zoom
  1297 2D8F 00					.byte	$00			; no pattern
  1298 2D90 08					.byte	%00001000		; NOT last entry, copy mode
  1299 						

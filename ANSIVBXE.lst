  1150 2CD8			cursor_on	.local				; turn on the cursor
  1151 				; but ONLY if the cursor isn't already on
  1152 2CD8 24 8C				bit	cursor_flg
  1153 2CDA 10 06				bpl	cursor_toggle
  1154 2CDC 60			skip		rts
  1155 						.endl
  1156 						
  1157 2CDD			cursor_off	.local				; turn off the cursor
  1158 				; but ONLY if the cursor isn't already off
  1159 2CDD 24 8C				bit	cursor_flg
  1160 2CDF 30 01				bmi	cursor_toggle
  1161 2CE1 60			skip		rts
  1162 						.endl

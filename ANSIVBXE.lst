  1174 2CF1			kbd_irq		.local
  1175 				; some of this code is based on the OS keyboard IRQ code. It even reuses some of the same OS variables.
  1176
  1177 2CF1 AD 09 D2				lda	KBCODE			; get the key
  1178 2CF4 CD F2 02				cmp	CH1			; and check if it's the same as last time
  1179 2CF7 D0 08				bne	new_key			; if not, then it's definitely a new press
  1180 2CF9 AD F1 02				lda	KEYDEL			; but if not, we need to see if it's too soon (and therefore a bounce)
  1181 2CFC F0 03				beq	new_key			; so if it is not, then it's a new press
  1182 2CFE 4C 26 2D				jmp	bounce			; otherwise, it's a bounce
  1183 						
  1184 2D01 8A			new_key		txa
  1185 2D02 48					pha				; we are going to need X
  1186 2D03 A9 03				lda	#$03			; we put this back in keydel so we can check for bounce again
  1187 2D05 8D F1 02				sta	KEYDEL
  1188 2D08 AD 09 D2				lda	KBCODE			; if it's not, then we need the keycode again
  1189 2D0B 8D F2 02				sta	CH1			; and we put it in here so we can check for bounce next time
  1190
  1191 				; I guess I will convert the key code to ASCII here, and interpret it, etc.
  1192 				; I'll probably use an LUT
  1193 				; for now, I guess I will just convert to ASCII and send. everything (for now) will become one character.
  1194 				; return will produce CR I suppose. (for now only of course)
  1195
  1196 2D0E AA					tax
  1197 2D0F BD 7F 2E				lda	keycode_table,x		; get the ascii conversion (if there is one) from the table
  1198 2D12 F0 0C				beq	no_value		; if it's 0, then we don't do anything
  1199
  1200 2D14 A6 91				ldx	sendbufend		; get the current offset in the send FIFO
  1201 2D16 E8					inx				; increment it
  1202 2D17 E4 90				cpx	sendbufstart		; if it's now the same as this, then the buffer is actually full
  1203 2D19 F0 05				beq	no_value		; we can't really do anything here, or else we'll cause a buffer overrun
  1204 2D1B 86 91				stx	sendbufend		; but otherwise we're fine, so this becomes the new value
  1205 						
  1206 2D1D 9D 8F 30				sta	send_buffer,x		; and we can put the character into the buffer here
  1207
  1208 2D20 A9 00		no_value	lda	#$00			; key down, so reset ATRACT counter
  1209 2D22 85 4D				sta	ATRACT			; not that it matters so much with VBXE, but it'll prevent changing border colors
  1210 2D24 68					pla
  1211 2D25 AA					tax				; get x back
  1212
  1213 2D26 A9 30		bounce		lda	#$30			; we still set the repeat timer on a bounce I guess
  1214 2D28 8D 2B 02				sta	SRTIMR			; that's the way the OS does it
  1215 2D2B 68					pla				; apparently the routine which jumps through the keyboard vector pushes A
  1216 2D2C 40					rti				; RTI because interupt
  1217 						.endl
  1218 						
  1219 2D2D			check_sendbuf	.local				; checks to see if the send buffer is empty, and sends it if it's not.
  1220 				; in the future, there may be a few different cases handled here.
  1221 				; the first is an empty buffer, so you return.
  1222 				; the second is a nonempty buffer, but only one character in the buffer (probably the next most common case next to no characters).
  1223 				; the third is a nonempty buffer with multiple characters in it
  1224 				; this one breaks down into two more cases, one where the bytes are contiguous, the other where they cross the end of the buffer
  1225 				; perhaps it's possible to prevent this case by resetting the buffer indexes to 0 once the buffer is empty.
  1226 				; however, this could conflict with the keyboard interupt if the interupt fires while inside this routine.
  1227 				; Right now, the only thing saving me from having to disable interupts for that scenario is that I never modify sendbufend
  1228 				; outside of the KBD IRQ
  1229
  1230 2D2D A5 90				lda	sendbufstart
  1231 2D2F C5 91				cmp	sendbufend
  1232 2D31 D0 01				bne	not_empty		; jump if the buffer isn't empty
  1233 						
  1234 2D33 60					rts				; or return otherwise
  1235
  1236 2D34 A2 10		not_empty	ldx	#$10			; for now, we send one character out of the buffer
  1237 2D36 A9 0B				lda	#$0B			; this will probably be the most common non-empty possibility anyway
  1238 2D38 8D 52 03				sta	ICCOM+$10		; it'll still handle multiple characters in the buffer too, just a little more slowly
  1239 2D3B A9 00				lda	#$00			; buffer length 0 uses character in accumulator
  1240 2D3D 8D 58 03				sta	ICBL + $10
  1241 2D40 8D 59 03				sta	ICBL + $11
  1242 2D43 A9 0D				lda	#$0D
  1243 2D45 8D 5A 03				sta	ICAX1 + $10		; turns out you need this for GET or it doesn't work.
  1244 2D48 A4 90				ldy	sendbufstart		; get index of last byte sent (use Y because X isn't free)
  1245 2D4A C8					iny				; increment it to get the next byte to be sent
  1246 2D4B 84 90				sty	sendbufstart		; update it
  1247 2D4D B9 8F 30				lda	send_buffer, y		; get the character at the index
  1248 2D50 4C 56 E4				jmp	CIOV			; and send it.
  1249 						.endl

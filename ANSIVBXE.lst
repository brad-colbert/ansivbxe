  1463 				; zero means 'do nothing' for now
  1464 				;		.byte	ascii-val		;key number - ascii mapping - atari key
  1465
  1466 2E7F 6C			keycode_table	.byte	$6C			;0 - l - l
  1467 2E80 6A					.byte	$6A			;1 - j - j
  1468 2E81 3B					.byte	$3B			;2 - ; - ;
  1469 2E82 00					.byte	0			;3 - no key
  1470 2E83 00					.byte	0			;4 - no key

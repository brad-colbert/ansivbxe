  1308 2DA0 00					.byte	0			; filling with a pattern
  1309 2DA1 00					.byte	0			; fill value is 0
  1310 2DA2 00					.byte	0			; no collisions
  1311 2DA3 00					.byte	0			; 1:1 zoom
